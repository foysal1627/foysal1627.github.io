<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>💀 C2 SERVER \\ CHAT LOGS</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            background-color: #04060a;
            color: #ffffff;
            font-family: 'DM Mono', monospace;
            padding: 40px 20px;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #ff1744;
            padding-bottom: 15px;
            margin-bottom: 30px;
        }
        .header h2 {
            color: #ff1744;
            font-size: 1.4rem;
            letter-spacing: 2px;
        }
        .refresh-btn {
            background: #ff1744;
            color: #fff;
            border: none;
            padding: 8px 16px;
            cursor: pointer;
            font-family: 'DM Mono', monospace;
            font-weight: 900;
            letter-spacing: 1px;
            border-radius: 3px;
            transition: 0.2s;
        }
        .refresh-btn:hover {
            background: #b2102f;
        }
        .log-card {
            background: rgba(10, 15, 24, 0.9);
            border: 1px solid #1e293b;
            border-left: 4px solid #ff1744;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 4px;
        }
        .meta-header {
            font-size: 0.75rem;
            color: #64748b;
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid #1e293b;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }
        .ip-badge {
            background: #111b27;
            padding: 2px 6px;
            border-radius: 3px;
            color: #ff1744;
        }
        .msg-row {
            margin-bottom: 12px;
            line-height: 1.5;
            font-size: 0.9rem;
        }
        .user-msg { color: #cbd5e1; }
        .bot-msg { color: #94a3b8; }
        .status-text {
            color: #00e5ff;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h2>💀 [C2_SERVER \\ CHAT_LOGS] </h2>
        <button class="refresh-btn" onclick="loadLogs()">REFRESH_</button>
    </div>
    
    <div id="logs-container"></div>
</div>

<script>

const DASHBOARD_WORKER_URL = 'https://wandering-rain-e523.foysalmahmud1627.workers.dev'; 

async function loadLogs() {
    const container = document.getElementById('logs-container');
    
  
    const DASHBOARD_SECRET_KEY = prompt("🔒 ENTER ACCESS KEY FOR C2 SERVER:");
    
    if (!DASHBOARD_SECRET_KEY) {
        container.innerHTML = "<p style='color: #ff1744;'>[ACCESS DENIED // NO KEY PROVIDED]</p>";
        return;
    }

    container.innerHTML = "<p class='status-text'>⚡ ESTABLISHING SAFE CONNECTION TO KV SERVER...</p>";

    try {
       
        const res = await fetch(`${DASHBOARD_WORKER_URL}/api/get-logs?key=${DASHBOARD_SECRET_KEY}`);
        
        if (!res.ok) throw new Error("ACCESS DENIED // INVALID ACCESS TOKEN");
        
        const logs = await res.json();
        container.innerHTML = ""; 

        if (logs.length === 0) {
            container.innerHTML = "<p style='color: #64748b;'>[NO LOGS RECORDED IN DATABASE]</p>";
            return;
        }

        logs.forEach(log => {
            const rawLog = typeof log === 'string' ? JSON.parse(log) : log;
            
            const logHTML = `
                <div class="log-card">
                    <div class="meta-header">
                        <span>🌐 <strong>IP_ADDR :</strong> <code class="ip-badge">${rawLog.ip}</code></span>
                        <span>⏰ <strong>TIMESTAMP :</strong> ${rawLog.time}</span>
                    </div>
                    <div class="msg-row">
                        <p class="user-msg"><strong style="color: #ff1744;">[USER] 👤 </strong> ${rawLog.user}</p>
                    </div>
                    <div class="msg-row">
                        <p class="bot-msg"><strong style="color: #00e5ff;">[AI_BOT] 🤖 </strong> ${rawLog.bot}</p>
                    </div>
                </div>
            `;
            container.innerHTML += logHTML;
        });

    } catch (err) {
        container.innerHTML = `<p style='color: #ff1744; font-weight: bold;'>❌ CONNECTION_FAILED: ${err.message}</p>`;
    }
}

window.onload = loadLogs;
</script>

</body>
</html>
